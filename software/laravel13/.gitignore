# ============================================
# 🔴 CRITICAL SECURITY (NEVER UPLOAD)
# ============================================

# Environment files with sensitive data
.env
.env.*
!.env.example
.env.backup
.env.production
.env.local
.env.staging

# Database backups (CRITICAL!)
*.sql
*.sql.gz
*.sql.zip
*.dump
*.db
*.sqlite

# Laravel encryption keys
*.key
storage/*.key
storage/oauth-private.key
storage/oauth-public.key

# Log files (can expose system paths)
*.log
storage/logs/*.log
storage/logs/*.log.*

# ============================================
# 🟡 DEPENDENCIES (Auto-generated, can reinstall)
# ============================================

# Composer
/vendor/
composer.lock
composer.phar
.auth.json

# NPM
/node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# 🟡 LARAVEL CACHE & TEMP FILES
# ============================================

# Laravel bootstrap cache
/bootstrap/cache/
/bootstrap/cache/*.php

# Laravel storage framework
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/testing/
/storage/framework/views/
/storage/framework/schedule-*
/storage/pail/

# Laravel compiled assets
/public/build/
/public/hot/
/public/storage/
/public/css/app.css
/public/js/app.js
/public/mix-manifest.json
/public/vite-manifest.json

# Laravel debug files
/storage/debugbar/
_ide_helper.php
.phpstorm.meta.php

# ============================================
# 🟢 IDE & EDITOR FILES (Personal)
# ============================================

# PHPStorm / IntelliJ
/.idea/
*.iml
/.fleet/

# VS Code
/.vscode/
*.code-workspace

# Nova
/.nova/

# Zed
/.zed/

# Sublime Text
*.sublime-*

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# Vim
*.swp
*.swo
*.swn

# ============================================
# 🟢 OPERATING SYSTEM FILES
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.document

