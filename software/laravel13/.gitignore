.phpunit.result.cache
.phpunit.cache/
.coverage
.coverage/
coverage/
tests/coverage/
tests/Browser/screenshots/
tests/Browser/console/

# Pest
.pest

# ============================================
# 🟡 BACKUP & ARCHIVE FILES
# ============================================

# General backups
*.backup
*.old
*.orig
*.rej
*.bak
*.tmp
*.temp
*.cache

# Archive files
*.zip
*.tar
*.gz
*.rar
*.7z

# ============================================
# 🟡 PROJECT-SPECIFIC FILES
# ============================================

# Session files (if using file driver)
storage/framework/sessions/*

# Image uploads (if using local storage)
public/uploads/
storage/app/public/

# Laravel Telescope (if installed)
/telescope/

# Laravel Pulse (if installed)
/storage/pulse/

# ============================================
# 🟢 DEPLOYMENT & TOOLS
# ============================================

# Deployment scripts
deploy.sh
deploy.yml
*.deploy

# CI/CD
.github/workflows/
.gitlab-ci.yml
.travis.yml

# Docker
docker-compose.override.yml
.env.docker
Dockerfile

# Homestead (Laravel)
Homestead.json
Homestead.yaml
.env.homestead

# Vagrant
.vagrant/

# ============================================
# 🟡 API KEYS & SECRETS
# ============================================

# Certificates and keys
*.pem
*.crt
*.p12
*.csr

# Service account files
service-account.json
*.service-account.json
*.google-services.json

# ============================================
