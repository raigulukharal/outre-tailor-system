.php_cs.cache

# Laravel IDE Helper
_ide_helper_models.php

# PHPStan
.phpstan.result.cache

# Laravel Sail
docker-compose.yml

# ============================================
# ✅ IMPORTANT: FILES THAT SHOULD BE TRACKED
# ============================================
!.env.example
!.gitattributes
!.gitignore
!README.md
!composer.json
!package.json
!artisan
!server.php